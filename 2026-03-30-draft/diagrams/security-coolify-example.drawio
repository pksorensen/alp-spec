    <mxCell id="phase2" value="JOB: deploy-production   —   coolify-deploy action in proxy mode (PKS_TOKEN present)" style="text;html=1;strokeColor=none;fillColor=#fff2cc;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;spacingLeft=8;" vertex="1" parent="1">
