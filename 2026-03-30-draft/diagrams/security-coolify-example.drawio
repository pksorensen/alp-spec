    <mxCell id="arr_reg_req" value="GET /registry/credential?hostname=registry.kjeldager.io&#xa;Authorization: Bearer PKS_TOKEN" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#82b366;fontSize=10;endArrow=block;endFill=1;" edge="1" parent="1">
