      <mxGeometry x="240" y="668" relative="1" as="geometry"><Array as="points"><mxPoint x="240" y="668"/><mxPoint x="160" y="668"/></Array></mxGeometry>
    </mxCell>

    <!-- trigger deploy via socket -->
    <mxCell id="s2b" value="Trigger deploy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="80" y="682" width="140" height="44" as="geometry" />
    </mxCell>
    <mxCell id="arr_trig" value="POST /coolify/deploy?environment=production&#xa;Authorization: Bearer PKS_TOKEN" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#82b366;fontSize=10;endArrow=block;endFill=1;" edge="1" parent="1">
      <mxGeometry x="220" y="704" relative="1" as="geometry"><Array as="points"><mxPoint x="220" y="704"/><mxPoint x="420" y="704"/></Array></mxGeometry>
    </mxCell>

    <!-- Runner calls Coolify with real token -->
    <mxCell id="s2c" value="Token swap: PKS_TOKEN&#xa;→ real COOLIFY_TOKEN&#xa;Call Coolify webhook" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=11;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="650" y="686" width="180" height="60" as="geometry" />
    </mxCell>
    <mxCell id="arr_sock_fwd2" value="forwarded to runner" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#6c8ebf;fontSize=10;endArrow=block;endFill=1;" edge="1" parent="1">
      <mxGeometry x="540" y="716" relative="1" as="geometry"><Array as="points"><mxPoint x="540" y="716"/><mxPoint x="650" y="716"/></Array></mxGeometry>
    </mxCell>
    <mxCell id="arr_coolify_call" value="GET /api/v1/deploy?uuid=app-uuid&#xa;Authorization: Bearer real_COOLIFY_TOKEN" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#6c8ebf;fontSize=10;endArrow=block;endFill=1;strokeWidth=2;" edge="1" parent="1">
      <mxGeometry x="830" y="716" relative="1" as="geometry"><Array as="points"><mxPoint x="830" y="716"/><mxPoint x="1270" y="716"/></Array></mxGeometry>
    </mxCell>
    <mxCell id="s_coolify" value="Build triggered&#xa;Pulls new image from registry" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="1180" y="698" width="180" height="52" as="geometry" />
    </mxCell>
    <mxCell id="arr_deploy_resp" value="{deployment_uuid: &quot;dep-xxx&quot;}" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#666666;fontColor=#333;fontSize=10;dashed=1;endArrow=open;endFill=0;" edge="1" parent="1">
      <mxGeometry x="830" y="758" relative="1" as="geometry"><Array as="points"><mxPoint x="1180" y="758"/><mxPoint x="830" y="758"/></Array></mxGeometry>
    </mxCell>
    <mxCell id="arr_deploy_resp2" value="deployment_uuid forwarded to job" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#82b366;fontColor=#333;fontSize=10;dashed=1;endArrow=open;endFill=0;" edge="1" parent="1">
      <mxGeometry x="240" y="776" relative="1" as="geometry"><Array as="points"><mxPoint x="420" y="776"/><mxPoint x="240" y="776"/></Array></mxGeometry>
    </mxCell>

    <!-- Phase 3: Poll -->
    <mxCell id="phase3" value="POLLING — job polls build status and health check via socket every 15s" style="text;html=1;strokeColor=none;fillColor=#e8f4fd;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;spacingLeft=8;" vertex="1" parent="1">
      <mxGeometry x="20" y="800" width="1560" height="28" as="geometry" />
    </mxCell>

    <mxCell id="s3a" value="Poll loop every 15s&#xa;GET /coolify/deployments/dep-xxx" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="80" y="836" width="200" height="52" as="geometry" />
    </mxCell>
    <mxCell id="arr_poll" value="→ socket → runner → Coolify /api/v1/deployments/dep-xxx" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#82b366;fontSize=10;endArrow=block;endFill=1;" edge="1" parent="1">
      <mxGeometry x="280" y="862" relative="1" as="geometry"><Array as="points"><mxPoint x="280" y="862"/><mxPoint x="1270" y="862"/></Array></mxGeometry>
    </mxCell>
    <mxCell id="arr_poll_resp" value="status: finished → health check → status: running (healthy)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#666666;fontColor=#333;fontSize=10;dashed=1;endArrow=open;endFill=0;" edge="1" parent="1">
      <mxGeometry x="280" y="888" relative="1" as="geometry"><Array as="points"><mxPoint x="1270" y="888"/><mxPoint x="280" y="888"/></Array></mxGeometry>
    </mxCell>
    <mxCell id="s3b" value="result=success&#xa;Comment on GitHub Release" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="80" y="904" width="200" height="48" as="geometry" />
    </mxCell>

    <!-- ── CREDENTIAL LEGEND (right side) ──────────────────── -->
    <mxCell id="cred_box" value="🔑  CREDENTIAL ARCHITECTURE&#xa;&#xa;What the job sees:&#xa;• PKS_TOKEN (scoped JWT, injected by runner)&#xa;• /var/run/pks-creds/creds.sock (mounted)&#xa;&#xa;What the runner holds (never in job env):&#xa;• Real registry password for registry.kjeldager.io&#xa;• Real COOLIFY_TOKEN&#xa;&#xa;Socket endpoints used:&#xa;• GET /registry/credential?hostname=...&#xa;• GET /coolify/token?environment=...&#xa;• POST /coolify/deploy?environment=...&#xa;• GET /coolify/deployments/{uuid}&#xa;&#xa;Token is masked with ::add-mask::&#xa;before passing to docker login" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="1400" y="140" width="180" height="380" as="geometry" />
    </mxCell>

    <!-- pks runner stored config box -->
    <mxCell id="runner_box" value="⚙️  pks runner config&#xa;(host, never in container)&#xa;&#xa;registry: registry.kjeldager.io&#xa;  username: pks&#xa;  password: &lt;real token&gt;&#xa;&#xa;coolify:&#xa;  token: &lt;COOLIFY_TOKEN&gt;&#xa;  apps:&#xa;    production: {webhook, fqdn}&#xa;    staging: {webhook, fqdn}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="640" y="240" width="210" height="200" as="geometry" />
