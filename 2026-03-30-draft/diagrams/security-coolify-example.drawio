    <!-- socket forwards to runner -->
    <mxCell id="arr_reg_fwd" value="lookup stored credential" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#6c8ebf;fontSize=10;endArrow=block;endFill=1;" edge="1" parent="1">
