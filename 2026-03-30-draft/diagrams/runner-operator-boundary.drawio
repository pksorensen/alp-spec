<mxfile host="app.diagrams.net" modified="2026-04-04" version="24.0.0">
  <diagram name="Runner-Operator Boundary" id="runner-operator-boundary">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Runner / Operator Trust Boundary -- What Crosses the Sandbox Wall" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;fontSize=15;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1560" height="40" as="geometry" />
        </mxCell>

        <!-- Runner box (HOST) -->
        <mxCell id="runner_box" value="Runner (pks-cli HOST)" style="swimlane;startSize=40;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=13;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="580" height="840" as="geometry" />
        </mxCell>

        <mxCell id="r_poll" value="Polling Loop&#xa;POST /runners/jobs" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="runner_box">
          <mxGeometry x="30" y="60" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="r_plugin" value="Plugin Acquisition&#xa;docker volume create alp-plugins-{jobId}&#xa;docker run alpine/git clone into volume" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="runner_box">
          <mxGeometry x="30" y="150" width="240" height="70" as="geometry" />
        </mxCell>
        <mxCell id="r_cred" value="Credential Server&#xa;Unix socket: /run/alp/cred.sock&#xa;Issues JIT-scoped tokens on request" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="runner_box">
          <mxGeometry x="30" y="260" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="r_egress" value="Egress Proxy (optional)&#xa;host-gateway:3128&#xa;Allow-list + audit log" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="runner_box">
          <mxGeometry x="30" y="360" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="r_spawn" value="Devcontainer Spawner&#xa;devcontainer up&#xa;injects mounts + env vars" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="runner_box">
          <mxGeometry x="30" y="460" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="r_monitor" value="Process Monitor&#xa;Watches Operator exit code" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="runner_box">
          <mxGeometry x="30" y="560" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="r_report" value="Result Reporter&#xa;PATCH /runners/{id}&#xa;jobResult: success | failed" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="runner_box">
          <mxGeometry x="30" y="650" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="r_cleanup" value="Cleanup&#xa;docker volume rm alp-plugins-{jobId}" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="runner_box">
          <mxGeometry x="30" y="750" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="r_note" value="Holds all real credentials.&#xa;Reaches marketplace directly.&#xa;Creates and controls the sandbox." style="text;html=1;strokeColor=#6c8ebf;fillColor=#e8f4fc;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontStyle=2;rounded=1;" vertex="1" parent="runner_box">
          <mxGeometry x="300" y="60" width="240" height="80" as="geometry" />
        </mxCell>

        <!-- Sandbox wall label -->
        <mxCell id="wall_label" value="SANDBOX WALL" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontStyle=3;fontSize=11;fontColor=#CC0000;rotation=-90;" vertex="1" parent="1">
          <mxGeometry x="650" y="460" width="120" height="30" as="geometry" />
        </mxCell>
        <mxCell id="wall_line" value="" style="line;strokeWidth=4;strokeColor=#FF3333;fillColor=none;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="685" y="80" width="10" height="840" as="geometry" />
        </mxCell>

        <!-- Operator + Agent box (devcontainer) -->
        <mxCell id="op_box" value="Operator + Agent (devcontainer)" style="swimlane;startSize=40;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=13;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="740" y="80" width="860" height="840" as="geometry" />
        </mxCell>

        <!-- vibecast sub-box -->
        <mxCell id="vib_box" value="Operator (vibecast)" style="swimlane;startSize=30;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=11;rounded=1;" vertex="1" parent="op_box">
          <mxGeometry x="30" y="60" width="360" height="420" as="geometry" />
        </mxCell>
        <mxCell id="v1" value="Launch script runs&#xa;reads AGENTICS_* and VIBECAST_*" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="vib_box">
          <mxGeometry x="20" y="50" width="300" height="50" as="geometry" />
        </mxCell>
        <mxCell id="v2" value="Reads VIBECAST_EXTRA_PLUGINS&#xa;builds --plugin-dir flags" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="vib_box">
          <mxGeometry x="20" y="140" width="300" height="50" as="geometry" />
        </mxCell>
        <mxCell id="v3" value="Starts Claude Code&#xa;with --plugin-dir /run/alp/plugins/...&#xa;and initial prompt" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="vib_box">
          <mxGeometry x="20" y="230" width="300" height="60" as="geometry" />
        </mxCell>
        <mxCell id="v4" value="stop_broadcast received&#xa;tmux session exits (code 0 = success)" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="vib_box">
          <mxGeometry x="20" y="340" width="300" height="50" as="geometry" />
        </mxCell>

        <!-- Claude sub-box -->
        <mxCell id="ag_box" value="Agent (Claude Code)" style="swimlane;startSize=30;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=11;rounded=1;" vertex="1" parent="op_box">
          <mxGeometry x="450" y="60" width="360" height="420" as="geometry" />
        </mxCell>
        <mxCell id="ag1" value="Loads skills from --plugin-dir&#xa;(/run/alp/plugins/{id})" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="ag_box">
          <mxGeometry x="20" y="50" width="300" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ag2" value="Calls /var/run/pks-creds socket&#xa;to get JIT service tokens" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="ag_box">
          <mxGeometry x="20" y="140" width="300" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ag3" value="Executes task&#xa;reads/writes workspace&#xa;uses skills and tools" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="ag_box">
          <mxGeometry x="20" y="230" width="300" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ag4" value="Calls stop_broadcast MCP tool&#xa;conclusion: success | failure" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="ag_box">
          <mxGeometry x="20" y="340" width="300" height="50" as="geometry" />
        </mxCell>

        <!-- Op note -->
        <mxCell id="op_note" value="No real credentials inside the container.&#xa;Workload identity only (ALP_JOB_ID).&#xa;Credential requests go back through socket to Runner." style="text;html=1;strokeColor=#82b366;fillColor=#eaf5e9;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontStyle=2;rounded=1;" vertex="1" parent="op_box">
          <mxGeometry x="30" y="530" width="770" height="60" as="geometry" />
        </mxCell>

        <!-- In-process note (below both boxes) -->
        <mxCell id="inprocess_note" value="In-process mode (dev only): pks-cli and vibecast share the same filesystem. Runner clones plugins to .agentics/_work/plugins/{jobId}/ directly. VIBECAST_EXTRA_PLUGINS points to those local paths -- no Docker volume needed." style="rounded=1;whiteSpace=wrap;fillColor=#ffffcc;strokeColor=#999900;fontSize=10;fontStyle=2;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="940" width="1560" height="50" as="geometry" />
        </mxCell>

        <!-- Crossing arrows -->
        <mxCell id="c1" value="[in] Volume mounts at container start&#xa;workspace, alp-plugins-{jobId} -&gt; /run/alp/plugins, cred.sock" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#0066CC;strokeWidth=2;fontSize=10;fontStyle=1;fillColor=#dae8fc;" edge="1" parent="1" source="r_spawn" target="v1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="c2" value="[in] Env vars: VIBECAST_EXTRA_PLUGINS, AGENTICS_JOB_ID, AGENTICS_TOKEN, AGENTICS_BASE_URL, ASSEMBLY_LINE_REPO_URL/TOKEN" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#007700;strokeWidth=2;fontSize=10;fontStyle=1;fillColor=#d5e8d4;exitX=1;exitY=0.7;exitDx=0;exitDy=0;entryX=0;entryY=0.3;entryDx=0;entryDy=0;" edge="1" parent="1" source="r_spawn" target="v1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="c3" value="[out] Exit code (0=success, non-zero=failed)" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#AA0000;strokeWidth=2;fontSize=10;fontStyle=1;fillColor=#f8cecc;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="v4" target="r_monitor">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="c4" value="[out/in] Credential request via Unix socket&#xa;Agent asks -&gt; Runner validates -&gt; issues JIT token" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#AA6600;strokeWidth=2;fontSize=10;fontStyle=1;fillColor=#fff2cc;dashed=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="ag2" target="r_cred">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
